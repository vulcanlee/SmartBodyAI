<div class="patient-view-container">
    <!-- Header -->
    <header>
        <div class="header-container">
            <div class="header-left">
                <img src="img/ncku_logo.svg" alt="成大醫院">
                <img src="img/ncku_header.png" alt="成大醫院">
            </div>
            <h1 class="header-title">身體組成AI分析</h1>
        </div>
    </header>

    <!-- Progress Steps -->
    <div class="progress-container">
        <div class="progress-step active">
            <div class="progress-step-icon">!</div>
            <span class="progress-step-text">確認基本資料</span>
        </div>
        <span class="progress-arrow">→</span>
        <div class="progress-step">
            <div class="progress-step-icon">1</div>
            <span class="progress-step-text">上傳DICOM</span>
        </div>
        <span class="progress-arrow">→</span>
        <div class="progress-step">
            <div class="progress-step-icon">2</div>
            <span class="progress-step-text">進行AI推論</span>
        </div>
        <span class="progress-arrow">→</span>
        <div class="progress-step">
            <div class="progress-step-icon">3</div>
            <span class="progress-step-text">查看AI分析</span>
        </div>
    </div>

<!-- Main Content -->
<main class="main-content">
    <!-- Left Section - ID Input -->
    <div>
        <h2 class="id-input-title">病歷號：</h2>
        <input type="text" @bind="patientMrm"
               placeholder="請輸入病歷號"
               class="id-input-field">
        <div class="btn-container">
            <button class="btn-confirm" @onclick="@(async () => { await OnPatientSendAsync();})">
                確認
            </button>
        </div>

            <!-- Info Box -->
            <div class="info-box">
                <p class="info-box-title">
                    <span class="info-box-icon">?</span>
                    何謂DICOM？
                </p>
                <p class="info-box-text">DICOM 是醫療影像的標準格式,可用來分析身體組成</p>
            </div>
        </div>

    <div>
        <div class="patient-card">
            <div class="patient-header">
                <span class="patient-name">@patientInformation.Name</span>
                <span class="patient-age">@patientInformation.GetAge()</span>
            </div>
            <div class="patient-body">
                <div class="patient-details">
                    <p><span>性別：</span><span>@patientInformation.Gender</span></p>
                    <p><span>身高：</span><span>@patientInformation.GetHeight()</span></p>
                    <p><span>體重：</span><span>@patientInformation.GetWeight()</span></p>
                </div>
            </div>
        </div>
    </div>

    <!-- Right Section - DICOM Viewer -->
    <div>
        <div class="dicom-card">
            <div class="dicom-header">
                <h3 class="dicom-title">DICOM</h3>
            </div>
            <div class="dicom-body">
                <div class="dicom-viewer">
                    <img src="@($"{image}?v={imageVersion}")"
                         alt="DICOM CT Scan">
                </div>
                <div class="dicom-buttons">
                    <button class="btn-select-dicom" @onclick="@(async () => await OnShowUploadDicomDialogAsync())">
                        <span>⬆️</span>
                        <span>選擇DICOM影像</span>
                    </button>
                    <button class="btn-ai-inference">
                        AI推論
                    </button>
                </div>
            </div>
        </div>
    </div>
</main>

    <!-- Footer -->
    <footer class="page-footer">
        <div class="footer-logo">
            <img src="img/exentric.png" alt="eXentric">
        </div>
        <div class="footer-buttons">
            <button class="btn-result" @onclick="OnViewResult">
                <span>🔍</span>
                <span>查看結果</span>
            </button>
        </div>
    </footer>
</div>

<UploadDicomDialog OpenPicker=ShowUploadDicomDialog
                   SubjectNo="@SubjectNo"
                   OnConfirmCallback=OnUploadDicomAsync />
